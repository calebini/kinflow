# CTX-002 Golden Verification Environment Template
# Usage:
#   set -a
#   source /home/agent/projects/apps/kinflow/ops/verify_ctx002_golden.env.example
#   set +a
#   /home/agent/projects/apps/kinflow/ops/verify_ctx002_golden.sh

# Output root for per-run artifacts
OUTPUT_ROOT=/home/agent/projects/_backlog/output

# Daemon service to restart and inspect
SERVICE_NAME=kinflow-daemon.service

# SQLite DB path for delivery assertion stage
KINFLOW_DB_PATH=/home/agent/projects/apps/kinflow/.anchor_runtime.sqlite

# Journal health polling controls
JOURNAL_LINES=500
HEALTH_WAIT_TIMEOUT_SEC=90
HEALTH_POLL_INTERVAL_SEC=5

# Optional canary hook command (executed with: bash -lc "$CANARY_COMMAND")
# Leave empty to skip canary stage.
CANARY_COMMAND=

# Optional non-mutating validation mode for tooling checks.
# 0 = full execution (includes sudo systemctl restart)
# 1 = dry-run for restart/canary stage behaviors (final verdict expected FAIL due mandatory restart/journal/db gating)
VERIFY_CTX002_GOLDEN_DRY_RUN=0
